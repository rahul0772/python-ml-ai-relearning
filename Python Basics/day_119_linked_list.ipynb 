        "# ================================\n",
        "# LINKED LIST IN PYTHON CODE\n",
        "# ================================\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# NODE CLASS\n",
        "# ==========================================\n",
        "\n",
        "class Node:\n",
        "\n",
        "    def __init__(self, data):\n",
        "\n",
        "        # Store value\n",
        "        self.data = data\n",
        "\n",
        "        # Store next node address\n",
        "        self.next = None\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# LINKED LIST CLASS\n",
        "# ==========================================\n",
        "\n",
        "class LinkedList:\n",
        "\n",
        "    def __init__(self):\n",
        "\n",
        "        # Head pointer\n",
        "        self.head = None\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # DISPLAY LINKED LIST\n",
        "    # ======================================\n",
        "\n",
        "    def display(self):\n",
        "\n",
        "        if self.head is None:\n",
        "            print(\"Linked List is Empty\")\n",
        "            return\n",
        "\n",
        "        temp = self.head\n",
        "\n",
        "        while temp:\n",
        "\n",
        "            print(temp.data, end=\" -> \")\n",
        "\n",
        "            temp = temp.next\n",
        "\n",
        "        print(\"None\")\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # INSERT AT BEGINNING\n",
        "    # ======================================\n",
        "\n",
        "    def insert_beginning(self, data):\n",
        "\n",
        "        new_node = Node(data)\n",
        "\n",
        "        # New node points to current head\n",
        "        new_node.next = self.head\n",
        "\n",
        "        # Move head to new node\n",
        "        self.head = new_node\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # INSERT AT END\n",
        "    # ======================================\n",
        "\n",
        "    def insert_end(self, data):\n",
        "\n",
        "        new_node = Node(data)\n",
        "\n",
        "        # If list is empty\n",
        "        if self.head is None:\n",
        "\n",
        "            self.head = new_node\n",
        "            return\n",
        "\n",
        "        temp = self.head\n",
        "\n",
        "        # Traverse till last node\n",
        "        while temp.next:\n",
        "\n",
        "            temp = temp.next\n",
        "\n",
        "        # Connect last node to new node\n",
        "        temp.next = new_node\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # INSERT AT POSITION\n",
        "    # ======================================\n",
        "\n",
        "    def insert_position(self, position, data):\n",
        "\n",
        "        # Invalid position\n",
        "        if position < 0:\n",
        "\n",
        "            print(\"Invalid Position\")\n",
        "            return\n",
        "\n",
        "        # Insert at beginning\n",
        "        if position == 0:\n",
        "\n",
        "            self.insert_beginning(data)\n",
        "            return\n",
        "\n",
        "        new_node = Node(data)\n",
        "\n",
        "        temp = self.head\n",
        "        current_position = 0\n",
        "\n",
        "        # Move to previous position\n",
        "        while temp and current_position < position - 1:\n",
        "\n",
        "            temp = temp.next\n",
        "            current_position += 1\n",
        "\n",
        "        # Position out of range\n",
        "        if temp is None:\n",
        "\n",
        "            print(\"Position Out of Range\")\n",
        "            return\n",
        "\n",
        "        # Link nodes\n",
        "        new_node.next = temp.next\n",
        "        temp.next = new_node\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # INSERT AFTER VALUE\n",
        "    # ======================================\n",
        "\n",
        "    def insert_after(self, target, data):\n",
        "\n",
        "        temp = self.head\n",
        "\n",
        "        while temp:\n",
        "\n",
        "            if temp.data == target:\n",
        "\n",
        "                new_node = Node(data)\n",
        "\n",
        "                new_node.next = temp.next\n",
        "                temp.next = new_node\n",
        "\n",
        "                return\n",
        "\n",
        "            temp = temp.next\n",
        "\n",
        "        print(\"Target value not found\")\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # DELETE FROM BEGINNING\n",
        "    # ======================================\n",
        "\n",
        "    def delete_beginning(self):\n",
        "\n",
        "        if self.head is None:\n",
        "\n",
        "            print(\"Linked List is Empty\")\n",
        "            return\n",
        "\n",
        "        self.head = self.head.next\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # DELETE FROM END\n",
        "    # ======================================\n",
        "\n",
        "    def delete_end(self):\n",
        "\n",
        "        if self.head is None:\n",
        "\n",
        "            print(\"Linked List is Empty\")\n",
        "            return\n",
        "\n",
        "        # Single node\n",
        "        if self.head.next is None:\n",
        "\n",
        "            self.head = None\n",
        "            return\n",
        "\n",
        "        temp = self.head\n",
        "\n",
        "        # Move to second last node\n",
        "        while temp.next.next:\n",
        "\n",
        "            temp = temp.next\n",
        "\n",
        "        temp.next = None\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # DELETE BY VALUE\n",
        "    # ======================================\n",
        "\n",
        "    def delete_value(self, value):\n",
        "\n",
        "        if self.head is None:\n",
        "\n",
        "            print(\"Linked List is Empty\")\n",
        "            return\n",
        "\n",
        "        # Delete head node\n",
        "        if self.head.data == value:\n",
        "\n",
        "            self.head = self.head.next\n",
        "            return\n",
        "\n",
        "        temp = self.head\n",
        "\n",
        "        while temp.next and temp.next.data != value:\n",
        "\n",
        "            temp = temp.next\n",
        "\n",
        "        # Value not found\n",
        "        if temp.next is None:\n",
        "\n",
        "            print(\"Value not found\")\n",
        "            return\n",
        "\n",
        "        # Remove node\n",
        "        temp.next = temp.next.next\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # SEARCH ELEMENT\n",
        "    # ======================================\n",
        "\n",
        "    def search(self, key):\n",
        "\n",
        "        temp = self.head\n",
        "        position = 0\n",
        "\n",
        "        while temp:\n",
        "\n",
        "            if temp.data == key:\n",
        "\n",
        "                print(f\"{key} found at position {position}\")\n",
        "                return True\n",
        "\n",
        "            temp = temp.next\n",
        "            position += 1\n",
        "\n",
        "        print(f\"{key} not found\")\n",
        "        return False\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # COUNT NODES\n",
        "    # ======================================\n",
        "\n",
        "    def count_nodes(self):\n",
        "\n",
        "        count = 0\n",
        "        temp = self.head\n",
        "\n",
        "        while temp:\n",
        "\n",
        "            count += 1\n",
        "            temp = temp.next\n",
        "\n",
        "        return count\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # REVERSE LINKED LIST\n",
        "    # ======================================\n",
        "\n",
        "    def reverse(self):\n",
        "\n",
        "        previous = None\n",
        "        current = self.head\n",
        "\n",
        "        while current:\n",
        "\n",
        "            next_node = current.next\n",
        "\n",
        "            # Reverse pointer\n",
        "            current.next = previous\n",
        "\n",
        "            # Move forward\n",
        "            previous = current\n",
        "            current = next_node\n",
        "\n",
        "        self.head = previous\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # FIND MIDDLE NODE\n",
        "    # ======================================\n",
        "\n",
        "    def find_middle(self):\n",
        "\n",
        "        if self.head is None:\n",
        "\n",
        "            print(\"Linked List is Empty\")\n",
        "            return\n",
        "\n",
        "        slow = self.head\n",
        "        fast = self.head\n",
        "\n",
        "        while fast and fast.next:\n",
        "\n",
        "            slow = slow.next\n",
        "            fast = fast.next.next\n",
        "\n",
        "        print(\"Middle Node:\", slow.data)\n",
        "\n",
        "\n",
        "    # ======================================\n",
        "    # CLEAR LINKED LIST\n",
        "    # ======================================\n",
        "\n",
        "    def clear(self):\n",
        "\n",
        "        self.head = None\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# DRIVER CODE\n",
        "# ==========================================\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(\"LINKED LIST PROGRAM\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "# Create linked list object\n",
        "ll = LinkedList()\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# INSERT AT END\n",
        "# ==========================================\n",
        "\n",
        "ll.insert_end(10)\n",
        "ll.insert_end(20)\n",
        "ll.insert_end(30)\n",
        "\n",
        "print(\"\\nAfter Insert End:\")\n",
        "ll.display()\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# INSERT AT BEGINNING\n",
        "# ==========================================\n",
        "\n",
        "ll.insert_beginning(5)\n",
        "\n",
        "print(\"\\nAfter Insert Beginning:\")\n",
        "ll.display()\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# INSERT AT POSITION\n",
        "# ==========================================\n",
        "\n",
        "ll.insert_position(2, 15)\n",
        "\n",
        "print(\"\\nAfter Insert at Position:\")\n",
        "ll.display()\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# INSERT AFTER VALUE\n",
        "# ==========================================\n",
        "\n",
        "ll.insert_after(20, 25)\n",
        "\n",
        "print(\"\\nAfter Insert After:\")\n",
        "ll.display()\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# SEARCH\n",
        "# ==========================================\n",
        "\n",
        "print(\"\\nSearch Operation:\")\n",
        "ll.search(30)\n",
        "ll.search(100)\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# COUNT NODES\n",
        "# ==========================================\n",
        "\n",
        "print(\"\\nTotal Nodes:\", ll.count_nodes())\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# FIND MIDDLE\n",
        "# ==========================================\n",
        "\n",
        "ll.find_middle()\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# DELETE FROM BEGINNING\n",
        "# ==========================================\n",
        "\n",
        "ll.delete_beginning()\n",
        "\n",
        "print(\"\\nAfter Delete Beginning:\")\n",
        "ll.display()\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# DELETE FROM END\n",
        "# ==========================================\n",
        "\n",
        "ll.delete_end()\n",
        "\n",
        "print(\"\\nAfter Delete End:\")\n",
        "ll.display()\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# DELETE BY VALUE\n",
        "# ==========================================\n",
        "\n",
        "ll.delete_value(20)\n",
        "\n",
        "print(\"\\nAfter Delete Value:\")\n",
        "ll.display()\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# REVERSE LINKED LIST\n",
        "# ==========================================\n",
        "\n",
        "ll.reverse()\n",
        "\n",
        "print(\"\\nAfter Reverse:\")\n",
        "ll.display()\n",
        "\n",
        "\n",
        "# ==========================================\n",
        "# CLEAR LINKED LIST\n",
        "# ==========================================\n",
        "\n",
        "ll.clear()\n",
        "\n",
        "print(\"\\nAfter Clear:\")\n",
        "ll.display()\n",
        "\n",
        "print(\"\\nProgram Completed\")"
